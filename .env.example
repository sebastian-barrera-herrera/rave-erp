# ─── Wompi (Pasarela de Pago Colombia) ───────────────────────
# Obtén estas llaves en https://comercios.wompi.co (sandbox o producción).
# - WOMPI_PUBLIC_KEY  → llave pública (se puede exponer en frontend)
# - WOMPI_PRIVATE_KEY → llave privada server-side (NO exponer)
# - WOMPI_EVENTS_KEY  → secreto para validar firmas de webhooks
# - WOMPI_INTEGRITY_KEY → secreto para firmar payment links
WOMPI_API_URL=https://sandbox.wompi.co/v1
WOMPI_PUBLIC_KEY=pub_test_xxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxx
WOMPI_EVENTS_KEY=test_events_xxxxxx
WOMPI_INTEGRITY_KEY=test_integrity_xxxxxx

